#!/usr/bin/env bash
# Pre-push hook: block tag pushes unless all CI checks have passed
# on the tagged commit.
#
# Setup (one-time):  git config core.hooksPath .githooks

set -euo pipefail

if ! command -v gh &>/dev/null; then
  echo "⚠  gh CLI not found — skipping tag CI check"
  exit 0
fi

while read -r local_ref local_oid remote_ref remote_oid; do
  # Only check tag pushes
  case "$local_ref" in
    refs/tags/v*) ;;
    *) continue ;;
  esac

  tag="${local_ref#refs/tags/}"
  version="${tag#v}"
  commit=$(git rev-list -n1 "$tag" 2>/dev/null || echo "$local_oid")

  # New tag must be strictly greater than the latest existing tag
  latest=$(git tag -l 'v*' | sort -V | tail -1)
  if [ -n "$latest" ]; then
    latest_version="${latest#v}"
    # sort -V puts the higher version last; if our version isn't last, it's out of order
    higher=$(printf '%s\n%s\n' "$latest_version" "$version" | sort -V | tail -1)
    if [ "$higher" = "$latest_version" ] && [ "$version" != "$latest_version" ]; then
      echo "❌ Tag $tag ($version) is not newer than existing $latest ($latest_version)"
      echo "   Tags must be strictly increasing. Bump the version number."
      exit 1
    fi
    echo "✅ Tag $tag is newer than $latest"
  fi

  # Tag must point to a commit on main
  if ! git merge-base --is-ancestor "$commit" main 2>/dev/null; then
    echo "❌ Tag $tag points to a commit not on main ($commit)"
    echo "   Merge to main first, then tag the main branch."
    exit 1
  fi
  echo "✅ Tag $tag is on main"

  # Run E2E tests before allowing a tag push
  if command -v podman &>/dev/null; then
    # Clean up orphaned E2E containers from prior failed runs
    stale=$(podman ps -q --filter "name=ha-e2e-" 2>/dev/null)
    if [ -n "$stale" ]; then
      echo "Cleaning up orphaned E2E containers..."
      echo "$stale" | xargs podman stop -t 5 2>/dev/null || true
    fi

    echo "Running E2E tests before tagging $tag..."
    if ! python -m pytest e2e/ -m slow -n auto --tb=short -q; then
      echo "❌ E2E tests failed — fix before pushing tag $tag"
      exit 1
    fi
    echo "✅ E2E tests passed"
  else
    echo "⚠  podman not found — skipping E2E tests"
  fi

  echo "Checking CI status for $tag ($commit)..."

  # Get check status — gh returns non-zero if any check failed
  status=$(gh run list --commit "$commit" --json status,conclusion \
    --jq '[.[] | select(.status == "completed")] | length' 2>/dev/null || echo "0")

  if [ "$status" = "0" ]; then
    echo "❌ No completed CI runs found for commit $commit"
    echo "   Push the commit first and wait for CI to pass before tagging."
    exit 1
  fi

  # Check if any run failed (cancelled runs are superseded, not broken)
  failed=$(gh run list --commit "$commit" --json status,conclusion \
    --jq '[.[] | select(.status == "completed" and .conclusion != "success" and .conclusion != "cancelled")] | length' 2>/dev/null || echo "0")

  if [ "$failed" != "0" ]; then
    echo "❌ CI checks failed for commit $commit"
    echo "   Fix the failures before pushing tag $tag."
    exit 1
  fi

  # Check the four required workflows completed
  completed=$(gh run list --commit "$commit" --json workflowName,conclusion \
    --jq '[.[] | select(.conclusion == "success")] | [.[].workflowName] | unique | sort | .[]' 2>/dev/null)

  missing=""
  for workflow in "HACS" "Hassfest" "Lint & Test"; do
    if ! echo "$completed" | grep -qxF "$workflow"; then
      missing="$missing  - $workflow"$'\n'
    fi
  done

  if [ -n "$missing" ]; then
    echo "❌ Required workflows not yet passed for $commit:"
    echo "$missing"
    echo "   Wait for all CI checks to complete before pushing tag $tag."
    exit 1
  fi

  echo "✅ All CI checks passed for $tag"
done

exit 0
