# Environment file for foxess-collect-ha.service.
#
# Copy this file to ~/.config/foxess-collect-ha.env and fill in your
# Home Assistant base URL and a long-lived access token. Do NOT commit
# the populated file — it contains a credential. Recommended: chmod 600.
#
#   cp systemd/foxess-collect-ha.env.example ~/.config/foxess-collect-ha.env
#   chmod 600 ~/.config/foxess-collect-ha.env
#   $EDITOR ~/.config/foxess-collect-ha.env
#
# The service's unit file loads this via EnvironmentFile= and the
# collector script reads HA_URL and HA_TOKEN from the environment.

HA_URL=https://ha.example.com
HA_TOKEN=replace-with-long-lived-access-token
